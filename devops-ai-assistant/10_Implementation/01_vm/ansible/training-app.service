[Unit]
Description=Training Flask Application
After=network.target

[Service]
Type=simple
User=training
WorkingDirectory=/opt/training-app/devops-ai-assistant/10_Implementation/01_vm
EnvironmentFile=/opt/training-app/devops-ai-assistant/10_Implementation/01_vm/.env
ExecStart=/opt/training-app/venv/bin/python app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target